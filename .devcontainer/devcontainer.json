{
  "build": {
    "dockerfile": "Dockerfile"
  },
  "privileged": true,
  "forwardPorts": [8444],
  "portsAttributes": {
    "8444": {
      "label": "KasmVNC Desktop",
      "onAutoForward": "openBrowser",
      "protocol": "https"
    }
  },
  "runArgs": ["--cap-add=SYS_ADMIN"],
  "postStartCommand": "vncserver :1 -select-de cinnamon -disableBasicAuth -websocketPort 8444"
}
